final as (
SELECT 
    -- tabela_velha.cliente_id,
    -- tabela_velha.nome,
    -- tabela_velha.cidade AS cidade_antiga,
    -- tabela_nova.cidade AS cidade_nova,
    -- tabela_velha.estado AS estado_antigo,
    -- tabela_nova.estado AS estado_novo,
