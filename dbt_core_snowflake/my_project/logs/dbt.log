consum_old AS (
    SELECT * FROM DBT_DB.PUBLIC.consum_old
    WHERE DSC_RECLAMACAO ILIKE '%Cobrança%'
),


consum_upgrade AS (
    SELECT * FROM DBT_DB.PUBLIC.consum_upgrade
    WHERE DSC_RECLAMACAO ILIKE '%Cobrança%'
),


base AS (
    SELECT 
        consum_old.*,
        consum_upgrade.*,
        CASE 
            WHEN consum_old.DSC_RECLAMACAO != consum_upgrade.DSC_RECLAMACAO
                THEN 'MUDOU'
            ELSE 'NÃO MUDOU'
        END AS STATUS
    FROM consum_old
    LEFT JOIN consum_upgrade
        ON consum_old.CPF_FORMATADO = consum_upgrade.CPF_FORMATADO
)

SELECT *
FROM base
WHERE STATUS = 'MUDOU'
  
  limit 5
