    CASE 
        WHEN tabela_velha.cidade != tabela_nova.cidade 
        THEN 'MUDOU A CIDADE'
        ELSE 'NÃO MUDOU'
    END AS status_cidade
FROM tabela_velha 
LEFT JOIN 
    tabela_nova 
    ON tabela_velha.cliente_id = tabela_nova.cliente_id
    WHERE tabela_velha.cidade   != tabela_nova.cidade
       OR tabela_velha.estado   != tabela_nova.estado
       OR tabela_velha.email    != tabela_nova.email
    ),

-- Tabela velha SEM os registros que mudaram
linhas_nao_alteradas AS (
    SELECT tabela_velha.*
    FROM tabela_velha
    WHERE cliente_id NOT IN (SELECT cliente_id FROM final)
)

-- Junta os não-mudados com os atualizados
SELECT * FROM linhas_nao_alteradas
UNION ALL
