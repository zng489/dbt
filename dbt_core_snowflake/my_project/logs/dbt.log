            FROM consum_old o
            LEFT JOIN consum_upgrade u
                ON o.CPF_FORMATADO = u.CPF_FORMATADO
        )

        SELECT CPF_FORMATADO
        FROM base
        WHERE STATUS = 'MUDOU'
    )
    AND is_current = TRUE
