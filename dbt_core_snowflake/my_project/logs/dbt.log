    SELECT 
        ingestion.*,
        method.DSC_RECLAMACAO AS DSC_RECLAMACAO_OLD,
        CASE 
            WHEN ingestion.DSC_RECLAMACAO != method.DSC_RECLAMACAO
                THEN 'MUDOU'
            ELSE 'NÃO MUDOU'
        END AS STATUS
    FROM ingestion 
    LEFT JOIN method 
        ON ingestion.CPF_FORMATADO = method.CPF_FORMATADO
)

SELECT *
FROM base
WHERE STATUS = 'MUDOU'
