                THEN 'MUDOU'
            ELSE 'NÃO MUDOU'
        END AS STATUS
    FROM ingestion 
    LEFT JOIN method 
        ON ingestion.CPF_FORMATADO = method.CPF_FORMATADO
)

SELECT *
FROM base
WHERE STATUS = 'MUDOU'
    )

