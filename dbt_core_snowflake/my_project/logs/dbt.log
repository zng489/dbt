SET cidade = final.cidade_nova,
    estado = final.estado_novo,
    email  = final.email_novo
FROM (
    WITH tabela_velha AS (
        SELECT * FROM scd_1
    ),
    tabela_nova AS (
        SELECT * FROM scd_2
    ),
    final AS (
        SELECT 
            tabela_velha.cliente_id,
            tabela_nova.cidade  AS cidade_nova,
            tabela_nova.estado  AS estado_novo,
            tabela_nova.email   AS email_novo
        FROM tabela_velha
